<Window x:Class="D201_Assignment_01.SelectUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select User" Height="400" Width="500">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Search by UserID or Name -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
      <TextBox x:Name="SearchUserBox" Width="200" Margin="0,0,5,0" ToolTip="Enter UserID or name to search"/>
      <Button Content="Search" Click="SearchUserButton_Click" Margin="0,0,5,0" Width="80"/>
      <Button Content="Clear" Click="ClearUserSearchButton_Click" Margin="0,0,0,0" Width="80"/>
    </StackPanel>

    <!-- List of Users -->
    <ListView Grid.Row="1" x:Name="listViewUsers" SelectionMode="Single">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="UserID" DisplayMemberBinding="{Binding UserID}" Width="80"/>
          <GridViewColumn Header="First Name" DisplayMemberBinding="{Binding FirstName}" Width="120"/>
          <GridViewColumn Header="Last Name" DisplayMemberBinding="{Binding LastName}" Width="120"/>
        </GridView>
      </ListView.View>
    </ListView>

    <!-- Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Select" Click="SelectUserButton_Click" Margin="0,0,5,0" Width="80"/>
      <Button Content="Cancel" Click="CancelButton_Click" Margin="0,0,0,0" Width="80"/>
    </StackPanel>
  </Grid>
</Window>