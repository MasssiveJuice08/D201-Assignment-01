<Window x:Class="D201_Assignment_01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D201_Assignment_01"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="900">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10">
      <!-- Buttons -->
      <StackPanel Orientation="Horizontal">
        <Button Content="Import Movie List" Click="ImportButton_Click" Margin="0,0,5,0" Padding="8,4"/>
        <Button Content="Export Movie List" Click="ExportButton_Click" Margin="0,0,5,0" Padding="8,4"/>
        <Button x:Name="ManageUsersBtn" Content="Manage Uers" Margin="0,0,5,0" Padding="8,4"/>
        <Button Content="Add Movie" Click="AddMovieButton_Click" Margin="0,0,5,0" Padding="8,4"/>
        <Button Content="Remove Movie" Click="RemoveMovieButton_Click" Margin="0,0,5,0" Padding="8,4"/>
        <Button Content="Sort by Title" Click="SortByTitleButton_Click" Margin="0,0,5,0" Padding="8,4"/>
        <Button Content="Sort by Year" Click="SortByYearButton_Click" Margin="0,0,5,0" Padding="8,4"/>
      </StackPanel>
      <!-- Search -->
      <TextBox x:Name="SearchBox" Width="250" Margin="0,0,0,0" ToolTip="Search"/>
    </StackPanel>
    
    <ListView Grid.Row="1" x:Name="listViewMovies">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="ID" DisplayMemberBinding="{Binding MovieID}" Width="100"/>
          <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="200"/>
          <GridViewColumn Header="Director" DisplayMemberBinding="{Binding Director}" Width="150"/>
          <GridViewColumn Header="Genre" DisplayMemberBinding="{Binding Genre}" Width="100"/>
          <GridViewColumn Header="Year" DisplayMemberBinding="{Binding ReleaseYear}" Width="80"/>
          <GridViewColumn Header="Available" DisplayMemberBinding="{Binding Available}" Width="60"/>
        </GridView>
      </ListView.View>
    </ListView>
  </Grid>
</Window>
