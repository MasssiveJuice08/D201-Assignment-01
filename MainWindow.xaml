<Window x:Class="D201_Assignment_01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D201_Assignment_01"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="1*"/>
      <RowDefinition Height="5*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal">
      <Button Content="Import Movie List" Click="ImportButton_Click"/>
      <Button Content="Export Movie List" Click="ExportButton_Click"/>
      <Button x:Name="ManageUsersBtn" Content="Manage Uers"/>
      <Button Content="Add Movie" Click="AddMovieButton_Click"/>
      <Button Content="Remove Movie" Click="RemoveMovieButton_Click"/>
      <!--<Button Content="Sort by Title" Click="SortByTitleButton_Click"/>
      <Button Content="Sort by Year" Click="SortByYearButton_Click"/>-->
      <TextBox x:Name="SearchBox" Width="300"></TextBox>
    </StackPanel>
    
    <ListView Grid.Row="1" x:Name="listViewMovies">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="ID" DisplayMemberBinding="{Binding MovieID}" Width="80"/>
          <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
          <GridViewColumn Header="Director" DisplayMemberBinding="{Binding Director}" Width="120"/>
          <GridViewColumn Header="Genre" DisplayMemberBinding="{Binding Genre}" Width="100"/>
          <GridViewColumn Header="Year" DisplayMemberBinding="{Binding ReleaseYear}" Width="80"/>
          <GridViewColumn Header="Available" DisplayMemberBinding="{Binding Available}" Width="60"/>
        </GridView>
      </ListView.View>
    </ListView>
  </Grid>
</Window>
