<Window x:Class="D201_Assignment_01.AddMovie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D201_Assignment_01"
        mc:Ignorable="d"
        Title="AddMovie" Height="450" Width="800">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="1*"></RowDefinition>
        <RowDefinition Height="5*"></RowDefinition>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Orientation="Horizontal">
        <Button x:Name="HomeBtn" Content="Home"></Button>
        <Button x:Name="AddUser" Content="Add User"></Button>
    </StackPanel>

      <DataGrid Grid.Row="1"></DataGrid>
  </Grid>
</Window>
